<Window x:Class="LocalAIAgent.Views.AppointmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LocalAIAgent.Views"
        mc:Ignorable="d"
        Title="Schedule Appointment"
        Height="350"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F3F3">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Client Name -->
        <TextBlock Text="Client Name" FontWeight="Bold"/>
        <TextBox Grid.Row="1"
                 Margin="0,5,0,15"
                 Text="{Binding ClientName}"
                 Height="28"/>

        <!-- Date -->
        <TextBlock Grid.Row="2" Text="Date" FontWeight="Bold"/>
        <DatePicker Grid.Row="3"
                    Margin="0,5,0,15"
                    SelectedDate="{Binding Date}"
                    Height="28"/>

        <!-- Time -->
        <TextBlock Grid.Row="4" Text="Time" FontWeight="Bold"/>
        <TextBox Grid.Row="5"
                 Margin="0,5,0,15"
                 Text="{Binding Time}"
                 Height="28"/>

        <!-- Duration -->
        <StackPanel Grid.Row="6" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Duration (minutes)" FontWeight="Bold"/>
            <TextBox Margin="0,5,0,0"
                     Text="{Binding DurationMinutes}"
                     Height="28"/>
        </StackPanel>

        <!-- Purpose -->
        <StackPanel Grid.Row="7" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Purpose" FontWeight="Bold"/>
            <TextBox Margin="0,5,0,0"
                     Text="{Binding Purpose}"
                     Height="60"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="OK"
                    Width="80"
                    Background="#009688"
                    Foreground="White"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
