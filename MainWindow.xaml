<Window x:Class="LocalAIAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local AI Automation Agent"
        Height="740" Width="1120"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Primary button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#546E7A"/>
        </Style>

        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#388E3C"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#D32F2F"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>

        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBdr" Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBdr" Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBdr" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="#ECEFF1">

        <!-- TOP HEADER BAR -->
        <Border DockPanel.Dock="Top" Background="#1976D2" Padding="18,11">
            <Grid>
                <TextBlock Text="Local AI Automation Agent"
                           FontSize="17" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,7,0"
                             Fill="{Binding StatusBrush}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BOTTOM STATUS BAR -->
        <Border DockPanel.Dock="Bottom" Background="#CFD8DC"
                BorderBrush="#B0BEC5" BorderThickness="0,1,0,0" Padding="14,5">
            <Grid>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="#455A64" FontSize="12"/>
                <ProgressBar HorizontalAlignment="Right" Width="200" Height="6"
                             IsIndeterminate="True" VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
            </Grid>
        </Border>

        <!-- MAIN TAB CONTROL -->
        <TabControl Background="Transparent" BorderThickness="0" Margin="10,8,10,0">

            <!-- ═══════════════════════════════════════════════
                 DASHBOARD TAB
            ═══════════════════════════════════════════════ -->
            <TabItem Header="Dashboard">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Action buttons -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Actions" Style="{StaticResource SectionHead}"/>
                            <WrapPanel Grid.Row="1">
                                <Button Content="🔄 Refresh Inbox"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding ConnectEmailCommand}"
                                        Margin="0,0,8,6"/>
                                <Button Content="Summarize PDF"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding SummarizePdfCommand}"
                                        Margin="0,0,8,6"/>
                                <Button Content="Daily Report"
                                        Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding GenerateDailyReportCommand}"
                                        Margin="0,0,8,6"/>
                                <Button Content="Schedule Appointment"
                                        Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding ScheduleAppointmentCommand}"
                                        Margin="0,0,8,6"/>
                                <Button Content="Check Availability"
                                        Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding ViewAvailabilityCommand}"
                                        Margin="0,0,0,6"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- AI Chat panel -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Ask AI" Style="{StaticResource SectionHead}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding AiQuery, UpdateSourceTrigger=PropertyChanged}"
                                         x:Name="AiQueryBox"/>
                                <Button Grid.Column="2" Content="Ask"
                                        Style="{StaticResource SuccessBtn}"
                                        Command="{Binding AskAiCommand}"
                                        Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Activity log -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Activity Log" Style="{StaticResource SectionHead}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Copy Log" Style="{StaticResource SecondaryBtn}"
                                            Command="{Binding CopyLogCommand}"
                                            Padding="10,4" Margin="0,0,6,0"/>
                                    <Button Content="Clear" Style="{StaticResource DangerBtn}"
                                            Command="{Binding ClearLogCommand}"
                                            Padding="10,4" Margin="0"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding LogText}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Foreground="#263238"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════
                 INBOX TAB
            ═══════════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Inbox"/>
                        <TextBlock Text="{Binding UnreadBadge}" Foreground="#E53935" FontWeight="Bold"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <!-- message list -->
                        <ColumnDefinition Width="300" MinWidth="200"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── LEFT: message list ── -->
                    <Border Style="{StaticResource Card}" Grid.Column="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource SectionHead}"
                                           VerticalAlignment="Center" Margin="0">
                                    <Run Text="Messages"/>
                                    <Run Text="{Binding UnreadBadge}" Foreground="#E53935"/>
                                </TextBlock>
                                <Button Content="🔄" Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding ConnectEmailCommand}"
                                        HorizontalAlignment="Right" Padding="8,3"
                                        ToolTip="Refresh inbox"/>
                            </Grid>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Emails}"
                                     SelectedItem="{Binding SelectedEmail}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding From}"
                                                           FontWeight="{Binding FontWeight}"
                                                           FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subject}"
                                                           FontWeight="{Binding FontWeight}"
                                                           FontSize="12" Opacity="0.8"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Preview}"
                                                           FontSize="11" Opacity="0.55"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Date, StringFormat='MMM d'}"
                                                       FontSize="11" Opacity="0.5"
                                                       VerticalAlignment="Top" Margin="6,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- GridSplitter -->
                    <GridSplitter Grid.Column="1" Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="#CFD8DC" ResizeBehavior="PreviousAndNext"/>

                    <!-- ── RIGHT: preview + reply ── -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200" MinHeight="100"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- empty state -->
                        <TextBlock Grid.RowSpan="5"
                                   Text="← Select a message to read it"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.4" FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedEmail}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- message header (visible when email selected) -->
                        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,4"
                                Visibility="{Binding HasSelectedEmail, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedEmail.Subject}"
                                           FontSize="16" FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="From: " Opacity="0.6" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedEmail.From}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,16,0"/>
                                    <TextBlock Text="Date: " Opacity="0.6" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedEmail.Date, StringFormat='ddd MMM d, yyyy  h:mm tt'}"
                                               FontSize="12" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- message body -->
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,4"
                                Visibility="{Binding HasSelectedEmail, Converter={StaticResource BoolVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding SelectedEmail.Body, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="13"
                                         Foreground="#263238"/>
                            </ScrollViewer>
                        </Border>

                        <!-- reply toolbar -->
                        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,4"
                                Visibility="{Binding HasSelectedEmail, Converter={StaticResource BoolVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Reply" Style="{StaticResource SectionHead}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <Button Content="✨ AI Draft Reply"
                                        Style="{StaticResource SuccessBtn}"
                                        Command="{Binding AiDraftReplyCommand}"
                                        Margin="0,0,8,0"
                                        ToolTip="Let AI write a reply based on the email content"/>
                                <Button Content="📤 Send Reply"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding SendReplyCommand}"
                                        ToolTip="Send the reply in the draft box below"/>
                            </StackPanel>
                        </Border>

                        <!-- reply draft editor -->
                        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,0"
                                Visibility="{Binding HasSelectedEmail, Converter={StaticResource BoolVis}}">
                            <TextBox Text="{Binding AiReplyDraft, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13"
                                     Foreground="#263238">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="Click '✨ AI Draft Reply' or type your reply here…"
                                                                           Foreground="#9E9E9E" Margin="4,4,0,0" FontSize="13"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════
                 EMAIL SETTINGS TAB (was "Email")
            ═══════════════════════════════════════════════ -->
            <TabItem Header="Email Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">

                        <!-- IMAP -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="IMAP  (Receive)" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Email Address" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Email}"/>

                                <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="EmailPasswordBox"
                                             PasswordChanged="EmailPasswordBox_PasswordChanged"/>

                                <!-- Gmail OAuth2 toggle -->
                                <CheckBox Content="Use Google OAuth2  (MFA browser sign-in — recommended)"
                                          IsChecked="{Binding UseGmailOAuth}"
                                          Margin="0,10,0,2" FontWeight="SemiBold"/>

                                <!-- OAuth2 credentials — visible when UseGmailOAuth = true -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UseGmailOAuth}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Border Background="#E8F5E9" BorderBrush="#A5D6A7"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="10,8" Margin="0,4,0,4">
                                        <TextBlock TextWrapping="Wrap" Foreground="#1B5E20" FontSize="12">
                                            <Run FontWeight="SemiBold">Setup:</Run>
                                            <Run> go to console.cloud.google.com → Enable Gmail API → Credentials → OAuth 2.0 Client ID (Desktop app). Paste the Client ID and Secret below.</Run>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Text="OAuth2 Client ID" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding GmailOAuthClientId}"/>

                                    <TextBlock Text="OAuth2 Client Secret" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox x:Name="GmailOAuthSecretBox"
                                                 PasswordChanged="GmailOAuthSecretBox_PasswordChanged"/>

                                    <Button Content="🔑  Re-authenticate (clear saved token)"
                                            Command="{Binding RevokeGmailOAuthCommand}"
                                            Margin="0,6,0,0" HorizontalAlignment="Left"
                                            ToolTip="Deletes the cached token so Google sign-in opens again on next connect"/>
                                </StackPanel>

                                <!-- App Password hint — visible when UseGmailOAuth = false -->
                                <Border Background="#FFF8E1" BorderBrush="#FFE082"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="10,8" Margin="0,6,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UseGmailOAuth}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠" Foreground="#F57F17"
                                                   FontSize="14" Margin="0,0,8,0"
                                                   VerticalAlignment="Top"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="#5D4037" FontSize="12">
                                            <Run FontWeight="SemiBold">Gmail users:</Run>
                                            <Run> your regular password will not work here — use a </Run>
                                            <Run FontWeight="SemiBold">Google App Password</Run>
                                            <Run> (myaccount.google.com → Security → App passwords), or enable OAuth2 above.</Run>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="IMAP Server" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ImapServer}"/>

                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="IMAP Port" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding ImapPort}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,4">
                                        <CheckBox Content="Use SSL/TLS" IsChecked="{Binding UseSsl}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SMTP -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="SMTP  (Send)" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="SMTP Server" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SmtpServer}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="SMTP Port" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding SmtpPort}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,4">
                                        <CheckBox Content="Use SSL/TLS" IsChecked="{Binding UseSmtpSsl}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Behavior -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Behavior" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Max emails to fetch" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding MaxEmailCount}" Width="120" HorizontalAlignment="Left"/>

                                <CheckBox Content="Auto-check email on startup"
                                          IsChecked="{Binding AutoCheckEmailOnStart}"
                                          Margin="0,10,0,0"/>

                                <TextBlock Text="Auto-refresh interval (minutes, 0 = disabled)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding EmailRefreshIntervalMinutes}"
                                         Width="120" HorizontalAlignment="Left"/>

                                <TextBlock Text="Email Signature" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding EmailSignature}" Height="80"
                                         TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Save Email Settings" Style="{StaticResource SuccessBtn}"
                                Command="{Binding SaveSettingsCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,16"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════
                 AI TAB
            ═══════════════════════════════════════════════ -->
            <TabItem Header="AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="API Configuration" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="ApiKeyBox"
                                             PasswordChanged="ApiKeyBox_PasswordChanged"/>

                                <TextBlock Text="AI Model" Style="{StaticResource FieldLabel}"/>
                                <ComboBox SelectedItem="{Binding AiModel}"
                                          ItemsSource="{Binding AiModelOptions}"/>

                                <TextBlock Text="API Endpoint  (leave default for OpenAI; change for local LLM)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding AiEndpoint}"/>

                                <TextBlock Text="Max Response Tokens" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding AiMaxTokens}" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="System Prompt" Style="{StaticResource SectionHead}"/>
                                <TextBlock Text="Controls how the AI assistant behaves across all operations."
                                           Foreground="#607D8B" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding AiSystemPrompt}" Height="110"
                                         TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Save AI Settings" Style="{StaticResource SuccessBtn}"
                                Command="{Binding SaveSettingsCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,16"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════
                 CALENDAR TAB
            ═══════════════════════════════════════════════ -->
            <TabItem Header="Calendar">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Calendar Provider" Style="{StaticResource SectionHead}"/>
                                <RadioButton Content="Google Calendar"
                                             IsChecked="{Binding UseGoogleCalendar}"
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="Microsoft Outlook / Office 365"
                                             IsChecked="{Binding UseOutlookCalendar}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Google Calendar" Style="{StaticResource SectionHead}"/>
                                <TextBlock Text="Client ID" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding GoogleClientId}"/>
                                <TextBlock Text="Client Secret" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="GoogleSecretBox"
                                             PasswordChanged="GoogleSecretBox_PasswordChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Microsoft / Outlook" Style="{StaticResource SectionHead}"/>
                                <TextBlock Text="Application (Client) ID" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding MicrosoftClientId}"/>
                                <TextBlock Text="Tenant ID" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding MicrosoftTenantId}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Behavior" Style="{StaticResource SectionHead}"/>
                                <TextBlock Text="Look-ahead days (how many days of events to fetch)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding CalendarLookAheadDays}"
                                         Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Save Calendar Settings" Style="{StaticResource SuccessBtn}"
                                Command="{Binding SaveSettingsCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,16"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════
                 APP SETTINGS TAB
            ═══════════════════════════════════════════════ -->
            <TabItem Header="App Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Startup" Style="{StaticResource SectionHead}"/>
                                <CheckBox Content="Start minimized to system tray"
                                          IsChecked="{Binding StartMinimized}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="Enable desktop notifications"
                                          IsChecked="{Binding EnableNotifications}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Reports" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Reports Output Folder" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ReportsFolder}"/>
                                    <Button Grid.Column="2" Content="Browse"
                                            Style="{StaticResource SecondaryBtn}"
                                            Command="{Binding BrowseReportsFolderCommand}"
                                            Padding="12,5" Margin="0"/>
                                </Grid>

                                <CheckBox Content="Schedule daily report automatically"
                                          IsChecked="{Binding ReportScheduleEnabled}"
                                          Margin="0,12,0,4"/>

                                <TextBlock Text="Report generation time (HH:mm)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ReportScheduleTime}"
                                         Width="120" HorizontalAlignment="Left"
                                         IsEnabled="{Binding ReportScheduleEnabled}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Logs" Style="{StaticResource SectionHead}"/>
                                <TextBlock Text="Retain log files for (days)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding LogRetentionDays}"
                                         Width="120" HorizontalAlignment="Left"/>
                                <TextBlock Text="Log files are stored in the Logs\ folder relative to the app."
                                           Foreground="#78909C" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Save App Settings" Style="{StaticResource SuccessBtn}"
                                Command="{Binding SaveSettingsCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,16"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
