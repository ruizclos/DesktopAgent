<Window x:Class="LocalAIAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LocalAIAgent"
        mc:Ignorable="d"
        Title="Local AI Automation Agent"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">

            <TextBlock Text="Settings"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Email -->
            <TextBlock Text="Email" FontWeight="Bold"/>
            <TextBox Text="{Binding Email}" Margin="0,5,0,15"/>

            <!-- IMAP Server -->
            <TextBlock Text="IMAP Server" FontWeight="Bold"/>
            <TextBox Text="{Binding ImapServer}" Margin="0,5,0,15"/>

            <!-- IMAP Port -->
            <TextBlock Text="IMAP Port" FontWeight="Bold"/>
            <TextBox Text="{Binding ImapPort}" Margin="0,5,0,15"/>

            <!-- SSL -->
            <CheckBox Content="Use SSL"
                      IsChecked="{Binding UseSsl}"
                      Margin="0,0,0,15"/>

            <!-- API Key -->
            <TextBlock Text="AI API Key" FontWeight="Bold"/>
            <PasswordBox x:Name="ApiKeyBox"
                         Margin="0,5,0,15"
                         PasswordChanged="ApiKeyBox_PasswordChanged"/>

            <!-- Reports Folder -->
            <TextBlock Text="Reports Folder" FontWeight="Bold"/>
            <TextBox Text="{Binding ReportsFolder}" Margin="0,5,0,15"/>

            <!-- Calendar Provider -->
            <TextBlock Text="Calendar Provider" FontWeight="Bold" Margin="0,10,0,5"/>

            <StackPanel Orientation="Vertical" Margin="0,0,0,15">
                <RadioButton Content="Google Calendar"
                             IsChecked="{Binding UseGoogleCalendar}"/>
                <RadioButton Content="Outlook Calendar"
                             IsChecked="{Binding UseOutlookCalendar}"/>
            </StackPanel>

            <!-- Save Settings -->
            <Button Content="Save Settings"
                    Command="{Binding SaveSettingsCommand}"
                    Background="#009688"
                    Foreground="White"
                    Height="32"/>
        </StackPanel>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ACTION BUTTONS -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="Connect Email"
                        Command="{Binding ConnectEmailCommand}"
                        Margin="0,0,10,0"
                        Width="140"/>

                <Button Content="Summarize PDF"
                        Command="{Binding SummarizePdfCommand}"
                        Margin="0,0,10,0"
                        Width="140"/>

                <Button Content="Daily Report"
                        Command="{Binding GenerateDailyReportCommand}"
                        Margin="0,0,10,0"
                        Width="140"/>

                <Button Content="Schedule Appointment"
                        Command="{Binding ScheduleAppointmentCommand}"
                        Margin="0,0,10,0"
                        Width="160"/>

                <Button Content="Check Availability"
                        Command="{Binding ViewAvailabilityCommand}"
                        Width="150"/>
            </StackPanel>

            <!-- STATUS -->
            <TextBlock Grid.Row="1"
                       Text="{Binding StatusText}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#444"
                       Margin="0,0,0,10"/>

            <!-- LOG OUTPUT -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Background="White"
                          BorderBrush="#DDD"
                          BorderThickness="1">
                <TextBlock Text="{Binding LogText}"
                           TextWrapping="Wrap"
                           Margin="10"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
