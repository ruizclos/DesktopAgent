<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Email -->
    <PackageReference Include="MailKit" Version="4.3.0" />

    <!-- PDF Parsing -->
    <PackageReference Include="iTextSharp.LGPLv2.Core" Version="1.7.1" />

    <!-- Google Calendar -->
    <PackageReference Include="Google.Apis.Calendar.v3" Version="1.68.0.3454" />
    <PackageReference Include="Google.Apis.Auth" Version="1.68.0" />

    <!-- Microsoft Graph Calendar -->
    <PackageReference Include="Microsoft.Graph" Version="5.36.0" />
    <PackageReference Include="Microsoft.Identity.Client" Version="4.61.0" />

    <!-- JSON -->
    <PackageReference Include="System.Text.Json" Version="8.0.0" />
  </ItemGroup>

</Project>